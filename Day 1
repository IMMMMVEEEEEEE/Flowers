      -webkit-background-clip:text;-webkit-text-fill-color:transparent;
      filter:drop-shadow(0 0 22px rgba(255,215,0,.85));margin-bottom:16px;">
      Yes! 🌸✨
    </div>
    <div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;
      font-size:clamp(1rem,2.4vw,1.6rem);color:rgba(255,230,245,.88);
